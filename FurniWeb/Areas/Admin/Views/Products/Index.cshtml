@model List<FurniWeb.Models.Product>
@{
    ViewData["Title"] = "Manage Products";
}

<div class="container mt-4">
    <h2>Manage Products</h2>

    <div class="mb-3">
        <a class="btn btn-primary" asp-area="Admin" asp-controller="Products" asp-action="Create">
            <i class="fas fa-plus"></i> Add New Product
        </a>
    </div>

    @if (Model.Count == 0)
    {
        <div class="alert alert-info">No products found. <a href="@Url.Action("Create", "Products", new { area = "Admin" })">Add one now</a></div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>#</th>
                        <th>Name</th>
                        <th>Price</th>
                        <th>Active</th>
                        <th style="width:200px;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var p in Model)
                    {
                        <tr>
                            <td>@p.Id</td>
                            <td>@p.Name</td>
                            <td>$@p.Price.ToString("F2")</td>
                            <td>
                                @if (p.IsActive)
                                {
                                    <span class="badge bg-success">Active</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Inactive</span>
                                }
                            </td>
                            <td>
                                <a class="btn btn-sm btn-warning" asp-area="Admin" asp-controller="Products" asp-action="Edit" asp-route-id="@p.Id">
                                    <i class="fas fa-edit"></i> Edit
                                </a>

                                <form method="post" asp-area="Admin" asp-controller="Products" asp-action="Delete" asp-route-id="@p.Id" style="display:inline;">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-sm btn-danger" 
                                            onclick="return confirm('Are you sure you want to delete this product?');">
                                        <i class="fas fa-trash"></i> Delete
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>