@model List<FurniWeb.Models.Product>
@{
    ViewData["Title"] = "Products";
    Layout = "_Layout";
}

<div class="page-header">
    <h1><i class="bi bi-box"></i> Products</h1>
    <a href="/Admin/Products/Create" class="btn btn-primary">
        <i class="bi bi-plus-circle"></i> Add New Product
    </a>
</div>

<div class="alert alert-info" role="alert">
    <i class="bi bi-info-circle"></i>
    <strong>How it works:</strong> 
    <ul class="mb-0 mt-2">
        <li><strong>Active products</strong> (green badge) are visible on the shop page</li>
        <li><strong>Inactive products</strong> (red badge) are hidden from the shop page but kept in the database</li>
        <li>Click <strong>Edit</strong> to change product details, price, image, or status</li>
        <li>Click <strong>Delete</strong> to permanently remove the product</li>
    </ul>
</div>

<div class="card">
    <div class="card-body">
        @if (Model?.Count > 0)
        {
            <div class="table-responsive">
                <table class="table table-hover">
                    <thead>
                        <tr>
                            <th>Product ID</th>
                            <th>Name</th>
                            <th>Price</th>
                            <th>Status</th>
                            <th>Image</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var product in Model)
                        {
                            <tr>
                                <td>#@product.Id</td>
                                <td>
                                    <strong>@product.Name</strong>
                                    @if (!string.IsNullOrEmpty(product.Description))
                                    {
                                        <br>
                                        <small class="text-muted">@product.Description?.Substring(0, Math.Min(50, product.Description.Length))...</small>
                                    }
                                </td>
                                <td>
                                    <strong>${@product.Price.ToString("N2")}</strong>
                                </td>
                                <td>
                                    @if (product.IsActive)
                                    {
                                        <span class="badge bg-success">Active</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger">Inactive</span>
                                    }
                                </td>
                                <td>
                                    @if (!string.IsNullOrEmpty(product.ImagePath))
                                    {
                                        <img src="@product.ImagePath" alt="@product.Name" style="max-height: 40px; max-width: 60px;">
                                    }
                                    else
                                    {
                                        <span class="text-muted">No Image</span>
                                    }
                                </td>
                                <td>
                                    <a href="/Admin/Products/Edit/@product.Id" class="btn btn-sm btn-warning" title="Edit product name, price, image, or status">
                                        <i class="bi bi-pencil"></i> Edit
                                    </a>
                                    <form method="post" action="/Admin/Products/Delete/@product.Id" style="display:inline;" onsubmit="return confirm('Are you sure? This will permanently delete the product.');">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm btn-danger" title="Permanently delete product">
                                            <i class="bi bi-trash"></i> Delete
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="alert alert-info" role="alert">
                <i class="bi bi-info-circle"></i>
                No products found. <a href="/Admin/Products/Create">Create the first product</a>
            </div>
        }
    </div>
</div>
