@model List<FurniWeb.Models.Product>

<h2>Shop</h2>

@if (!Model.Any())
{
    <p>No products yet.</p>
}
else
{
    foreach (var p in Model)
    {
        <div style="border:1px solid #ccc; padding:10px; margin-bottom:10px;">
            <h3>@p.Name</h3>
            <p>@p.Description</p>
            <p><b>@p.Price</b></p>

            @if (!string.IsNullOrEmpty(p.ImageUrl))
            {
                <img src="@p.ImageUrl" style="width:150px" />
            }
        </div>
    }
}