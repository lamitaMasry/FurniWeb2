@model List<FurniWeb.Areas.Admin.Controllers.OrdersController.AdminOrderVm>
@{
    ViewData["Title"] = "Orders";
    Layout = "_Layout";
}

<div class="page-header">
    <h1><i class="bi bi-cart-check"></i> Orders</h1>
</div>

<div class="card">
    <div class="card-body">
        @if (Model?.Count > 0)
        {
            <div class="table-responsive">
                <table class="table table-hover">
                    <thead>
                        <tr>
                            <th>Order ID</th>
                            <th>Customer Name</th>
                            <th>Email</th>
                            <th>Phone</th>
                            <th>Items</th>
                            <th>Total</th>
                            <th>Date</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var order in Model)
                        {
                            <tr>
                                <td><strong>#@order.Id</strong></td>
                                <td>@order.Name</td>
                                <td>@order.Email</td>
                                <td>@order.Phone</td>
                                <td>
                                    <span class="badge bg-info">@order.Items.Count item(s)</span>
                                </td>
                                <td>
                                    <strong>${@order.Total.ToString("N2")}</strong>
                                </td>
                                <td>
                                    @order.CreatedAtUtc.ToString("MMM dd, yyyy")
                                </td>
                                <td>
                                    <a href="/Admin/Orders/Details/@order.Id" class="btn btn-sm btn-info">
                                        <i class="bi bi-eye"></i> View
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="alert alert-info" role="alert">
                <i class="bi bi-info-circle"></i>
                No orders found yet.
            </div>
        }
    </div>
</div>
