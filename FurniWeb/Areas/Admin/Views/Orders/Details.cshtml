@model FurniWeb.Models.Order

<h2>Order #@Model.Id</h2>

<p><a class="btn btn-outline-secondary" href="/Admin/Orders">Back</a></p>

<div class="card mb-3">
    <div class="card-body">
        <h5>Customer</h5>
        <div><strong>Name:</strong> @Model.CustomerName</div>
        <div><strong>Email:</strong> @Model.Email</div>
        <div><strong>Phone:</strong> @Model.Phone</div>
        <div><strong>Date:</strong> @Model.CreatedAtUtc.ToLocalTime()</div>
    </div>
</div>

<div class="card mb-3">
    <div class="card-body">
        <h5>Address</h5>
        <div><strong>Country:</strong> @Model.Country</div>
        <div><strong>Address1:</strong> @Model.Address1</div>
        @if (!string.IsNullOrWhiteSpace(Model.Address2))
        {
            <div><strong>Address2:</strong> @Model.Address2</div>
        }
        <div><strong>State:</strong> @Model.State</div>
        <div><strong>ZIP:</strong> @Model.Zip</div>
        @if (!string.IsNullOrWhiteSpace(Model.OrderNotes))
        {
            <div><strong>Notes:</strong> @Model.OrderNotes</div>
        }
    </div>
</div>

<div class="card">
    <div class="card-body">
        <h5>Items</h5>

        @if (Model.Items == null || Model.Items.Count == 0)
        {
            <div class="alert alert-warning mb-0">No items found for this order.</div>
        }
        else
        {
            <table class="table table-sm table-bordered align-middle">
                <thead>
                    <tr>
                        <th>Product</th>
                        <th class="text-end">Unit Price</th>
                        <th class="text-end">Qty</th>
                        <th class="text-end">Line Total</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var it in Model.Items)
                    {
                        <tr>
                            <td>@it.ProductName</td>
                            <td class="text-end">$@it.UnitPrice</td>
                            <td class="text-end">@it.Quantity</td>
                            <td class="text-end">$@(it.UnitPrice* it.Quantity)</td>
                        </tr>
                    }
                </tbody>
                <tfoot>
                    <tr>
                        <th colspan="3" class="text-end">Total</th>
                        <th class="text-end">$@Model.TotalAmount</th>
                    </tr>
                </tfoot>
            </table>
        }
    </div>
</div>