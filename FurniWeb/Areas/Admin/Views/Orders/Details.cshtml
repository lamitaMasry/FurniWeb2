@model FurniWeb.Models.Order
@{
    ViewData["Title"] = "Order Details";
    Layout = "_Layout";
}

<div class="page-header">
    <h1><i class="bi bi-receipt"></i> Order Details #@Model.Id</h1>
    <a href="/Admin/Orders" class="btn btn-secondary">
        <i class="bi bi-arrow-left"></i> Back to Orders
    </a>
</div>

<div class="row">
    <!-- Customer Information -->
    <div class="col-md-6">
        <div class="card">
            <div class="card-header">
                <h5 class="mb-0">Customer Information</h5>
            </div>
            <div class="card-body">
                <div class="row mb-3">
                    <div class="col-sm-5">
                        <strong>Name:</strong>
                    </div>
                    <div class="col-sm-7">
                        @Model.FirstName @Model.LastName
                    </div>
                </div>
                <div class="row mb-3">
                    <div class="col-sm-5">
                        <strong>Email:</strong>
                    </div>
                    <div class="col-sm-7">
                        <a href="mailto:@Model.Email">@Model.Email</a>
                    </div>
                </div>
                <div class="row mb-3">
                    <div class="col-sm-5">
                        <strong>Phone:</strong>
                    </div>
                    <div class="col-sm-7">
                        <a href="tel:@Model.Phone">@Model.Phone</a>
                    </div>
                </div>
                <div class="row">
                    <div class="col-sm-5">
                        <strong>Order Date:</strong>
                    </div>
                    <div class="col-sm-7">
                        @Model.CreatedAtUtc.ToString("MMM dd, yyyy HH:mm")
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Shipping Address -->
    <div class="col-md-6">
        <div class="card">
            <div class="card-header">
                <h5 class="mb-0">Shipping Address</h5>
            </div>
            <div class="card-body">
                <p class="mb-0">
                    <strong>@Model.FirstName @Model.LastName</strong><br>
                    @Model.Address1<br>
                    @if (!string.IsNullOrEmpty(Model.Address2))
                    {
                        <text>@Model.Address2<br></text>
                    }
                    @Model.State, @Model.Zip<br>
                    @Model.Country
                </p>
            </div>
        </div>
    </div>
</div>

<!-- Order Items -->
<div class="row mt-4">
    <div class="col-md-12">
        <div class="card">
            <div class="card-header">
                <h5 class="mb-0">Order Items</h5>
            </div>
            <div class="card-body">
                @if (Model.Items?.Count > 0)
                {
                    <div class="table-responsive">
                        <table class="table">
                            <thead>
                                <tr>
                                    <th>Product Name</th>
                                    <th>Unit Price</th>
                                    <th>Quantity</th>
                                    <th class="text-end">Total</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model.Items)
                                {
                                    <tr>
                                        <td>@item.ProductName</td>
                                        <td>${@item.UnitPrice.ToString("N2")}</td>
                                        <td>@item.Quantity</td>
                                        <td class="text-end"><strong>${@(item.UnitPrice * item.Quantity).ToString("N2")}</strong></td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>

                    <div class="row">
                        <div class="col-md-6 offset-md-6">
                            <div class="card bg-light">
                                <div class="card-body">
                                    <div class="d-flex justify-content-between mb-2">
                                        <span>Subtotal:</span>
                                        <strong>${@Model.TotalAmount.ToString("N2")}</strong>
                                    </div>
                                    <div class="d-flex justify-content-between mb-2">
                                        <span>Shipping:</span>
                                        <strong>Free</strong>
                                    </div>
                                    <hr>
                                    <div class="d-flex justify-content-between">
                                        <span>Order Total:</span>
                                        <strong class="h5">${@Model.TotalAmount.ToString("N2")}</strong>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                }
                else
                {
                    <div class="alert alert-info">
                        No items in this order.
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<!-- Order Notes -->
@if (!string.IsNullOrEmpty(Model.OrderNotes))
{
    <div class="row mt-4">
        <div class="col-md-12">
            <div class="card">
                <div class="card-header">
                    <h5 class="mb-0">Order Notes</h5>
                </div>
                <div class="card-body">
                    @Model.OrderNotes
                </div>
            </div>
        </div>
    </div>
}
