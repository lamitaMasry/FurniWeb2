@{
    ViewData["Title"] = "Admin Dashboard";
}

<h2>Admin Dashboard</h2>

<div style="display:flex; gap:16px; flex-wrap:wrap; margin-top:16px;">
    <div style="border:1px solid #ddd; border-radius:12px; padding:16px; min-width:240px;">
        <div style="font-weight:600;">Total Products</div>
        <div style="font-size:28px; margin-top:8px;">@ViewBag.ProductsCount</div>
    </div>

    <div style="border:1px solid #ddd; border-radius:12px; padding:16px; min-width:240px;">
        <div style="font-weight:600;">Total Revenue</div>
        <div style="font-size:28px; margin-top:8px;">$@ViewBag.Revenue</div>
    </div>

    <div style="border:1px solid #ddd; border-radius:12px; padding:16px; min-width:240px;">
        <div style="font-weight:600;">Orders</div>
        <div style="font-size:28px; margin-top:8px;">@ViewBag.OrdersCount</div>
    </div>
</div>

<div style="margin-top:18px;">
    <a class="btn btn-primary" href="/Admin/Products">Manage Products</a>
    <a class="btn btn-outline-secondary" href="/Admin/Orders" style="margin-left:8px;">View Orders</a>
</div>