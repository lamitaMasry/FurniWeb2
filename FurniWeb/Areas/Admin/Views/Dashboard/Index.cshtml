@{
    ViewData["Title"] = "Dashboard";
    Layout = "_Layout";
}

<div class="page-header">
    <h1><i class="bi bi-speedometer2"></i> Dashboard</h1>
</div>

<!-- Key Stats -->
<div class="row">
    <div class="col-md-4">
        <div class="stat-card">
            <div class="stat-icon">
                <i class="bi bi-box"></i>
            </div>
            <div class="stat-value">@ViewBag.ProductsCount</div>
            <div class="stat-label">Total Products</div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="stat-card">
            <div class="stat-icon">
                <i class="bi bi-cart-check"></i>
            </div>
            <div class="stat-value">@ViewBag.OrdersCount</div>
            <div class="stat-label">Total Orders</div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="stat-card">
            <div class="stat-icon">
                <i class="bi bi-cash-coin"></i>
            </div>
            <div class="stat-value"><strong style="color: #28a745;">${@ViewBag.Revenue?.ToString("N2")}</strong></div>
            <div class="stat-label">Total Profit</div>
        </div>
    </div>
</div>

<!-- Dashboard Content -->
<div class="row mt-4">
    <div class="col-md-12">
        <div class="card">
            <div class="card-header">
                <h5 class="mb-0">Welcome to FurniWeb Admin Dashboard</h5>
            </div>
            <div class="card-body">
                <p>Welcome to your admin dashboard! Here you can manage:</p>
                <ul class="list-group list-group-flush">
                    <li class="list-group-item d-flex justify-content-between align-items-center">
                        <span>
                            <strong>Products</strong> - Add, edit, delete and manage your furniture products with images
                        </span>
                        <a href="/Admin/Products" class="btn btn-primary btn-sm">Manage</a>
                    </li>
                    <li class="list-group-item d-flex justify-content-between align-items-center">
                        <span>
                            <strong>Orders</strong> - View and track customer orders with names, addresses, emails and purchased items
                        </span>
                        <a href="/Admin/Orders" class="btn btn-primary btn-sm">View Orders</a>
                    </li>
                </ul>
            </div>
        </div>
    </div>
</div>
